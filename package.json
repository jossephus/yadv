{
	"name": "yadv",
	"version": "0.7.1",
	"description": "Yet another local diff viewer for git working trees",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jossephus/yadv.git"
	},
	"bugs": {
		"url": "https://github.com/jossephus/yadv/issues"
	},
	"homepage": "https://github.com/jossephus/yadv#readme",
	"keywords": [
		"diff",
		"git",
		"local",
		"terminal",
		"tui",
		"bun"
	],
	"files": [
		"bin",
		"dist",
		"README.md",
		".env.example",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"bin": {
		"yadv": "bin/yadv.js"
	},
	"scripts": {
		"build:cli": "bun run dev/build-cli.ts",
		"build:npm-packages": "bun run dev/build-npm-packages.ts",
		"build:standalone": "bun run dev/build-standalone.ts",
		"changeset": "npm exec --package @changesets/cli@2.31.0 -- changeset",
		"changeset:status": "npm exec --package @changesets/cli@2.31.0 -- changeset status",
		"changeset:version": "npm exec --package @changesets/cli@2.31.0 -- changeset version",
		"dev": "YADV_FORCE_FULL_REPAINT_ON_START=1 bun --watch src/index.tsx",
		"start": "bun run src/index.tsx",
		"test": "bun test test",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --tsconfig tsconfig.json src/ test/",
		"format": "oxfmt src/ test/ dev/",
		"format:check": "oxfmt --check src/ test/ dev/",
		"package:smoke": "bun run build:cli && node bin/yadv.js --version",
		"prepublishOnly": "printf '%s\n' 'Publish dist/npm/main, not the source checkout.' && exit 1",
		"prepack": "bun run build:cli"
	},
	"workspaces": [
		".",
		"packages/*"
	],
	"dependencies": {
		"@effect/atom-react": "4.0.0-beta.59",
		"@opentui/core": "0.2.1",
		"@opentui/react": "0.2.1",
		"effect": "4.0.0-beta.59",
		"react": "19.2.5",
		"scheduler": "0.27.0"
	},
	"devDependencies": {
		"@ghui/keymap": "workspace:*",
		"@effect/language-service": "0.85.1",
		"@types/bun": "1.3.12",
		"@types/react": "19.2.14",
		"oxfmt": "0.47.0",
		"oxlint": "1.62.0",
		"typescript": "6.0.2"
	}
}
