# Optional: override the git command timeout (milliseconds). Defaults to 15000.
# YADV_COMMAND_TIMEOUT_MS=15000

# Optional: override the config directory (themes, etc.).
# YADV_CONFIG_DIR=~/.config/yadv

# Optional local observability. Motel's default local port is 27686.
# YADV_MOTEL_PORT=27686
# YADV_OTLP_ENDPOINT=http://127.0.0.1:27686
